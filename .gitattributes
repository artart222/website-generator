# Normalize text files to LF in the repo and working tree (matches CI on Ubuntu).
* text=auto eol=lf

# Explicit binary assets (do not alter line endings).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.sqlite3 binary
